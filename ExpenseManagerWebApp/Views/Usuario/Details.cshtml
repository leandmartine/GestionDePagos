@model CasosUso.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Detalle Usuario";
}

<h1>Detalle Usuario</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@Model.Username</dd>

        <dt class="col-sm-2">Rol</dt>
        <dd class="col-sm-10">@Model.Rol</dd>

        <dt class="col-sm-2">Calle</dt>
        <dd class="col-sm-10">@Model.Calle</dd>

        <dt class="col-sm-2">Ciudad</dt>
        <dd class="col-sm-10">@Model.Ciudad</dd>

        <dt class="col-sm-2">Codigo Postal</dt>
        <dd class="col-sm-10">@Model.CodigoPostal</dd>
    </dl>
</div>
