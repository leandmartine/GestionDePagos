@model CasosUso.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<h2 class="text-danger">Eliminar Usuario</h2>
<hr />
<p class="text-muted">¿Está seguro que desea eliminar este usuario?</p>

<dl class="row">
    <dt class="col-sm-3">Username</dt>
    <dd class="col-sm-9">@Model.Username</dd>

    <dt class="col-sm-3">Rol</dt>
    <dd class="col-sm-9">@Model.Rol</dd>

    <dt class="col-sm-3">Ciudad</dt>
    <dd class="col-sm-9">@Model.Ciudad</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
</form>
