@model CasosUso.DTOs.MetodoPagoDTO

@{
    ViewData["Title"] = "Nuevo Método de Pago";
}

<h2>Nuevo Método de Pago</h2>
<hr />

@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Tarjeta de Crédito" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Detalle" class="form-label fw-bold">Detalle</label>
                <textarea asp-for="Detalle" class="form-control" rows="3"
                          placeholder="Ej: Visa terminada en 1234, débito automático, etc."></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
