@model IEnumerable<CasosUso.DTOs.LimiteGastoDTO>

@{
    ViewData["Title"] = "Límites de Gasto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Límites de Gasto</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo Límite</a>
</div>

@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Usuario</th>
            <th>Categoría</th>
            <th>Monto Máximo</th>
            <th>Valor de Alerta</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in Model)
    {
        <tr>
            <td>@l.Id</td>
            <td>@(l.UsernameUsuario ?? l.UsuarioId.ToString())</td>
            <td>@(l.NombreCategoria ?? l.CategoriaId.ToString())</td>
            <td>@l.MontoMaximo.ToString("N2")</td>
            <td>@l.ValorAlerta.ToString("N2")</td>
            <td>
                <a asp-action="Details" asp-route-id="@l.Id" class="btn btn-sm btn-info">Detalle</a>
                <a asp-action="Delete" asp-route-id="@l.Id" class="btn btn-sm btn-danger">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>
