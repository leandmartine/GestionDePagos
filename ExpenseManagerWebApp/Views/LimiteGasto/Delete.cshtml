@model CasosUso.DTOs.LimiteGastoDTO

@{
    ViewData["Title"] = "Eliminar Límite de Gasto";
}

<h2 class="text-danger">Eliminar Límite de Gasto</h2>
<hr />
<p class="text-muted">¿Está seguro que desea eliminar este límite de gasto?</p>

<dl class="row">
    <dt class="col-sm-3">Usuario</dt>
    <dd class="col-sm-9">@(Model.UsernameUsuario ?? Model.UsuarioId.ToString())</dd>

    <dt class="col-sm-3">Categoría</dt>
    <dd class="col-sm-9">@(Model.NombreCategoria ?? Model.CategoriaId.ToString())</dd>

    <dt class="col-sm-3">Monto Máximo</dt>
    <dd class="col-sm-9">$@Model.MontoMaximo.ToString("N2")</dd>

    <dt class="col-sm-3">Valor de Alerta</dt>
    <dd class="col-sm-9">$@Model.ValorAlerta.ToString("N2")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
</form>
